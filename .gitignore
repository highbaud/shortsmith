# Python venvs and caches
.venv/
audio-enhance/.venv/
whisperx-align/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Model checkpoints (downloaded at runtime)
audio-enhance/checkpoints/
audio-enhance/test/
whisperx-align/checkpoints/
checkpoints/
models/cache/

# Pipeline work artifacts
work/
*.log

# Generated media (never commit user-supplied videos / outputs)
*.mp4
*.mkv
*.webm
*.mov
*.wav
*.mp3
# But DO commit the bundled smoke-test sample, anything inside the kit, and
# the curated SFX pack (licensed for redistribution).
!examples/sample_clip.mp4
!hyperframes-student-kit/**/*.mp4
!hyperframes-student-kit/**/*.wav
!assets/sfx/**

# Local config (never commit secrets)
.env
.env.local

# Editor / OS junk
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Claude Code local session state (skills, etc.)
.claude/

# Build artifacts
dist/
build/
*.egg-info/

# Node / Remotion
remotion/node_modules/
node_modules/
npm-debug.log*

# Remotion auto-derived b-roll picks (regenerated per render)
**/broll.auto.json

# Network fetch cache (gen_broll.py)
.cache/

# Metricool publish state (post IDs, scheduled timestamps, account IDs —
# never commit; tokens live in ~/.claude/, never in this repo)
.publish-state.json
.metricool-cache/

# detect-secrets baseline scan artifact (committed elsewhere is fine, but
# the per-machine cache is not)
.secrets.cache/

# Internal / machine-specific handoff notes — never publish
PROJECT_STATE.md
*.local.md
/private/

# Publishing / scheduling working files (personal: brand ids, Drive maps,
# calendars, X rankings). Generated locally per run; never commit.
# Root-level hidden JSON catches .drive-map.json, .week1-*.json, .x60.json, etc.
/.*.json
metricool_payloads*.json
_build_*.py
# Root-level ad-hoc throwaway scripts (e.g. _x60_pick.py). Anchored to repo root
# so it never matches tracked package modules like shortsmith/_doctor.py.
/_*.py
