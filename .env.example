# Shortsmith configuration. Copy to .env and edit as needed.
# Existing environment variables always win over .env entries.

# Clip selection backend. Choose anthropic (best quality, API cost) or
# ollama (free, local, experimental). First-run wizard asks you on first use.
# SHORTSMITH_CLIP_ENGINE=anthropic        # anthropic | ollama

# REQUIRED for the anthropic engine (skip if using ollama).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Visual style preset for scaffolded shorts. First-run wizard asks on first use.
# SHORTSMITH_STYLE=xrp-revolution         # xrp-revolution | minimal | bold

# === Optional model / runtime overrides ===

# Whisper transcription
# SHORTSMITH_WHISPER_MODEL=large-v3       # small | medium | large-v2 | large-v3
# SHORTSMITH_WHISPER_DEVICE=cuda          # cuda | cpu
# SHORTSMITH_WHISPER_COMPUTE=float16      # float16 (GPU) | int8 (CPU) | int8_float16

# Anthropic Claude (when SHORTSMITH_CLIP_ENGINE=anthropic)
# SHORTSMITH_CLAUDE_MODEL=claude-opus-4-7
# SHORTSMITH_MIN_SCORE=7                  # 1-10 viral-score floor

# Local LLM (when SHORTSMITH_CLIP_ENGINE=ollama)
# SHORTSMITH_LOCAL_LLM_URL=http://localhost:11434/v1   # ollama default; LM Studio = http://localhost:1234/v1
# SHORTSMITH_LOCAL_LLM_MODEL=llama3.1:70b              # any model loaded into your server
# SHORTSMITH_LOCAL_LLM_TEMP=0.3                        # lower = more deterministic, fewer JSON errors

# Speech enhancement engine
# SHORTSMITH_ENHANCE=clearvoice           # clearvoice (recommended) | voicefixer | resemble | deepfilter

# === Optional path overrides ===
# All paths default to siblings of the shortsmith repo root.
# Set absolute paths here only if you want to point at projects living elsewhere.
# SHORTSMITH_KIT_ROOT=/abs/path/to/hyperframes-student-kit
# SHORTSMITH_TEMPLATE_REF=/abs/path/to/template-project
# SHORTSMITH_AUDIO_ENHANCE=/abs/path/to/audio-enhance
# SHORTSMITH_VIDEO_DIR=/abs/path/to/source-videos
