<template id="{{ comp_id }}-template">
  <div
    data-composition-id="{{ comp_id }}"
    data-start="0"
    data-width="1080"
    data-height="1920"
    data-duration="{{ '%.2f' | format(duration) }}"
  >
    <div class="co-panel">
      <div class="co-bg"></div>
      <div class="co-rule co-rule-top"></div>
      <div class="co-rule co-rule-bot"></div>
      <div class="co-stack">
        {% if eyebrow %}<div class="co-eyebrow">{{ eyebrow }}</div>{% endif %}
        <div class="co-line">
          {% for token in tokens %}
            <span class="co-word{% if token.accent %} co-accent{% endif %}">{{ token.text }}</span>{% if not loop.last %} {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    <style>
      [data-composition-id="{{ comp_id }}"] { position: absolute; inset: 0; }
      [data-composition-id="{{ comp_id }}"] .co-panel {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        font-family: "Montserrat", sans-serif;
        overflow: hidden;
      }
      [data-composition-id="{{ comp_id }}"] .co-bg {
        position: absolute; inset: 0;
        background:
          radial-gradient(ellipse 80% 60% at 50% 36%,
            #0f2033 0%, #0a1828 50%, #07121c 100%);
        opacity: 0;
      }
      [data-composition-id="{{ comp_id }}"] .co-rule {
        position: absolute; left: 80px; right: 80px; height: 4px;
        background: linear-gradient(90deg, transparent, #37bdf8 30%, #37bdf8 70%, transparent);
        opacity: 0; transform: scaleX(0); transform-origin: center;
        will-change: transform, opacity;
      }
      [data-composition-id="{{ comp_id }}"] .co-rule-top { top: 540px; }
      [data-composition-id="{{ comp_id }}"] .co-rule-bot { bottom: 540px; }
      [data-composition-id="{{ comp_id }}"] .co-stack {
        position: relative;
        max-width: 940px;
        text-align: center;
        opacity: 0;
        will-change: transform, opacity;
      }
      [data-composition-id="{{ comp_id }}"] .co-eyebrow {
        font-family: "Roboto Mono", "Montserrat", monospace;
        font-weight: 700;
        font-size: 32px;
        letter-spacing: 0.32em;
        color: #37bdf8;
        text-transform: uppercase;
        margin-bottom: 40px;
        text-shadow: 0 0 24px rgba(55, 189, 248, 0.6);
      }
      [data-composition-id="{{ comp_id }}"] .co-line {
        font-weight: 900;
        font-size: {{ font_size }}px;
        line-height: 1.02;
        letter-spacing: -0.02em;
        color: #ffffff;
        text-transform: uppercase;
        text-shadow:
          0 4px 0 #07121c,
          0 8px 30px rgba(0, 0, 0, 0.6);
      }
      [data-composition-id="{{ comp_id }}"] .co-word { display: inline-block; }
      [data-composition-id="{{ comp_id }}"] .co-accent {
        color: {{ accent_color }};
        text-shadow:
          0 4px 0 #07121c,
          0 0 24px {{ accent_color }}80,
          0 8px 30px rgba(0, 0, 0, 0.6);
      }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <script>
      (function () {
        const tl = gsap.timeline({ paused: true });
        const scope = '[data-composition-id="{{ comp_id }}"] ';
        const TOTAL = {{ '%.2f' | format(duration) }};
        const ENTRY = 0.22;
        const EXIT = 0.22;
        const HOLD_START = ENTRY;
        const EXIT_START = Math.max(TOTAL - EXIT, ENTRY + 0.05);

        // Panel background fades in just ahead of the text
        tl.to(scope + ".co-bg",
          { opacity: 1, duration: 0.14, ease: "power2.out" }, 0);
        tl.to(scope + ".co-rule",
          { opacity: 1, scaleX: 1, duration: 0.24, ease: "power3.out", stagger: 0.05 }, 0.04);

        // Text stack slams in with back ease + slight shake at the apex
        tl.fromTo(scope + ".co-stack",
          { opacity: 0, scale: 0.78, y: 18 },
          { opacity: 1, scale: 1, y: 0, duration: ENTRY, ease: "back.out(2.2)" }, 0.06);

        // Tiny per-word punch on accent words for emphasis
        tl.fromTo(scope + ".co-accent",
          { scale: 0.88 },
          { scale: 1.0, duration: 0.18, ease: "back.out(3)", stagger: 0.04 }, ENTRY);

        // Exit: drop and fade
        tl.to(scope + ".co-stack",
          { opacity: 0, scale: 0.92, y: -10, duration: EXIT, ease: "power2.in" }, EXIT_START);
        tl.to(scope + ".co-rule",
          { opacity: 0, scaleX: 0, duration: EXIT, ease: "power2.in" }, EXIT_START);
        tl.to(scope + ".co-bg",
          { opacity: 0, duration: EXIT + 0.05, ease: "power2.in" }, EXIT_START);

        tl.set({}, {}, TOTAL);

        window.__timelines = window.__timelines || {};
        window.__timelines["{{ comp_id }}"] = tl;
      })();
    </script>
  </div>
</template>
